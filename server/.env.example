# MongoDB Atlas connection string
# Replace with your actual MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/octane?retryWrites=true&w=majority

# JWT secret key for token signing
JWT_SECRET=change-this-to-a-random-secret-string

# Encryption key for AES-256-GCM user ID encryption (separate from JWT_SECRET; defaults to JWT_SECRET for backward compat)
ENCRYPTION_KEY=change-this-to-a-different-random-secret-string

# Server port
PORT=3001

# Node environment (production/development)
# In production, server serves built frontend static files and sets sameSite=none on session cookie
NODE_ENV=development

# Comma-separated list of allowed CORS origins (default: http://localhost:3000,http://127.0.0.1:3000)
# Example: CORS_ORIGINS=https://octane.example.com,https://www.example.com
CORS_ORIGINS=

# Brevo (formerly Sendinblue) API key for transactional emails
BREVO_API_KEY=

# From email address for Brevo emails
BREVO_FROM_EMAIL=noreply@octane.local

# Upstash Redis REST URL and token for rate limiting and session management
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# DOE PDF Aggregator API (soul-scraper)
# The deployed Render URL of the soul-scrape project
DOE_API_URL=https://soul-scaper.onrender.com
# Default fuel grade to display on map pins: ron91 | ron95 | ron97 | diesel
DOE_PREFERRED_GRADE=ron91
