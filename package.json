{
  "name": "octane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && bun run dev",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:server\"",
    "build": "vite build",
    "build:server": "cd server && bun run build",
    "build:all": "bun run build && bun run build:server",
    "start": "node server/dist/index.js",
    "serve": "vite preview"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "concurrently": "^10.0.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "solid-devtools": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.5",
    "vite-plugin-solid": "^2.11.12"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "maplibre-gl": "^5.24.0",
    "solid-js": "^1.9.13",
    "vite-plugin-pwa": "^1.3.0"
  }
}
