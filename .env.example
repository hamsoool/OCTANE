# MongoDB Atlas connection string
# Replace with your actual MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/octane?retryWrites=true&w=majority

# JWT secret key for token signing
JWT_SECRET=change-this-to-a-random-secret-string

# Server port (default 3001)
PORT=3001

# Frontend API URL (default /api — uses Vite dev proxy in dev, same-origin in prod)
# For cross-origin production deployment (e.g. separate frontend static site),
# set to the full backend URL, e.g. https://octane-api.onrender.com/api
VITE_API_URL=/api
